[pull]
    rebase = merges
[push]
    default = current
[rebase]
    autostash = true
[advice]
    statusHints = false
[color]
    ui = true
[completion]
    commands = -gitk
[fetch]
    prune = true
[ui]
    editor = vim
[url "git@github.com:"]
    insteadOf = "gh:"
    pushInsteadOf = "github:"
    pushInsteadOf = "git://github.com/"
[url "git@github.com:pcel/"]
    insteadOf = "https://github.com/pcel/"
[url "git@github.com:tusite/"]
    insteadOf = "https://github.com/tusite/"
[url "git@github.com:nextpcel/"]
    insteadOf = "https://github.com/nextpcel/"
[core]
	filemode = true
